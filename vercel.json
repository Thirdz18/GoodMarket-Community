{
  "version": 2,
  "builds": [
    {
      "src": "main.py",
      "use": "@vercel/python"
    },
    {
      "src": "api/wc/[...path].js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/wc/(.*)",
      "dest": "api/wc/[...path].js"
    },
    {
      "src": "/(.*)",
      "dest": "main.py"
    }
  ]
}
