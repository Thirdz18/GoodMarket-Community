# Core chain config
CELO_RPC_URL=https://forno.celo.org

# UBI gas fallback (server-side)
GAMES_KEY=0xyour_games_private_key
GOODDOLLAR_FAUCET_CONTRACT=0x4F93Fa058b03953C851eFaA2e4FC5C34afDFAb84
GOODDOLLAR_FAUCET_API_URL=https://goodserver.gooddollar.org/verify/topWallet

# Optional faucet tuning
# FAUCET_MIN_CELO is the minimum-floor threshold for the gas readiness check.
# Wallets with balance below max(dynamic_required, FAUCET_MIN_CELO) trigger a
# faucet top-up. Default 0.1 CELO covers typical end-to-end claim cost during
# congestion (the previous 0.002–0.005 floors were too low and let WC / Trust
# users false-pass with only 0.06 CELO).
FAUCET_MIN_CELO=0.1
FAUCET_BUFFER_MULTIPLIER=1.35
FAUCET_DUPLICATE_WINDOW_MIN=30

# Squid Router Buy Crypto widget (all OPTIONAL — every value defaults in code)
# The widget works out of the box with NO env vars: it ships with Squid's
# public "squid-swap-widget" integrator id, which authenticates against the
# Squid API without registration or contacting Squid support. Set
# SQUID_INTEGRATOR_ID only if you later register your own integrator id.
# SQUID_INTEGRATOR_ID=squid-swap-widget
# SQUID_API_URL=https://v2.api.squidrouter.com
# SQUID_FROM_CHAIN_ID=42220
# SQUID_TO_CHAIN_ID=8453
# Destination token defaults to native ETH on Base (Squid native placeholder):
# SQUID_TO_TOKEN=0xEeeeeEeeeEeEeeEeEeEeeEEEeeeeEeeeeeeeEEeE
# Optional Celo source-token address overrides (CELO/cUSD/USDC/USDT):
# SQUID_CELO_TOKEN=0xEeeeeEeeeEeEeeEeEeEeeEEEeeeeEeeeeeeeEEeE
# SQUID_CUSD_TOKEN=0x765DE816845861e75A25fCA122bb6898B8B1282a
# SQUID_USDC_TOKEN=0xcebA9300f2b948710d2653dD7B07f33A8B32118C
# SQUID_USDT_TOKEN=0x48065fbBE25f71C9282ddf5e1cD6D6A887483D5e
