# Core chain config
# Primary Celo RPC endpoint
CELO_RPC_URL=https://forno.celo.org
# Note: The app includes fallback RPCs (1rpc.io/celo, celo.publicnode.com)
# for reliability when the primary endpoint is rate-limited or unavailable.

# UBI gas fallback (server-side)
GAMES_KEY=0xyour_games_private_key
GOODDOLLAR_FAUCET_CONTRACT=0x4F93Fa058b03953C851eFaA2e4FC5C34afDFAb84
GOODDOLLAR_FAUCET_API_URL=https://goodserver.gooddollar.org/verify/topWallet

# Optional faucet tuning
# FAUCET_MIN_CELO is the minimum-floor threshold for the gas readiness check.
# Wallets with balance below max(dynamic_required, FAUCET_MIN_CELO) trigger a
# faucet top-up. Default 0.1 CELO covers typical end-to-end claim cost during
# congestion (the previous 0.002–0.005 floors were too low and let WC / Trust
# users false-pass with only 0.06 CELO).
FAUCET_MIN_CELO=0.1
FAUCET_BUFFER_MULTIPLIER=1.35
FAUCET_DUPLICATE_WINDOW_MIN=30

# MiniPay cUSD gas faucet (anti-farming controls)
# The faucet is gated on GoodDollar face verification (on-chain isWhitelisted),
# a per-wallet 48h cooldown, AND a global per-UTC-day disbursement cap. The cap
# bounds the worst-case pool drain across ALL wallets in one day; set it to 0 to
# disable. Sized as (expected daily unique claimers) * MINIPAY_CUSD_FAUCET_AMOUNT
# with headroom — tune to your pool size.
# MINIPAY_CUSD_FAUCET_AMOUNT=0.05
# MINIPAY_CUSD_FAUCET_DAILY_CAP=25
# MINIPAY_CUSD_FAUCET_COOLDOWN_SECONDS=172800

# Squid Router Buy Crypto widget (all OPTIONAL — every value defaults in code)
# The widget works out of the box with NO env vars: it ships with Squid's
# public "squid-swap-widget" integrator id, which authenticates against the
# Squid API without registration or contacting Squid support. Set
# SQUID_INTEGRATOR_ID only if you later register your own integrator id.
# SQUID_INTEGRATOR_ID=squid-swap-widget
# SQUID_API_URL=https://v2.api.squidrouter.com
# SQUID_FROM_CHAIN_ID=42220
# SQUID_TO_CHAIN_ID=8453
# Destination token defaults to native ETH on Base (Squid native placeholder):
# SQUID_TO_TOKEN=0xEeeeeEeeeEeEeeEeEeEeeEEEeeeeEeeeeeeeEEeE
# Optional Celo source-token address overrides (CELO/cUSD/USDC/USDT):
# SQUID_CELO_TOKEN=0xEeeeeEeeeEeEeeEeEeEeeEEEeeeeEeeeeeeeEEeE
# SQUID_CUSD_TOKEN=0x765DE816845861e75A25fCA122bb6898B8B1282a
# SQUID_USDC_TOKEN=0xcebA9300f2b948710d2653dD7B07f33A8B32118C
# SQUID_USDT_TOKEN=0x48065fbBE25f71C9282ddf5e1cD6D6A887483D5e

# ── P2P G$ Trading (onchain escrow + offchain Supabase) ────────────────
# P2P_KEY is the deployer wallet for P2PEscrow.sol and becomes the contract
# owner == arbiter. It is used ONLY for the admin-review path (seller rejected
# the buyer's proof) and dispute resolution — never for normal user actions.
# P2P_KEY=0xyour_p2p_owner_private_key
# Deployed P2PEscrow address (set after running contracts/deploy_p2p_escrow.py):
# P2P_ESCROW_CONTRACT_ADDRESS=0x...
# Buyer payment window in seconds (default 1800 = 30 min):
# P2P_PAYMENT_WINDOW_SECONDS=1800

# ── Turnkey embedded-wallet + Google social login ──────────────────────
TURNKEY_ORGANIZATION_ID=your-turnkey-org-id
TURNKEY_AUTH_PROXY_CONFIG_ID=your-turnkey-auth-proxy-config-id
TURNKEY_API_PUBLIC_KEY=your-turnkey-api-public-key
TURNKEY_API_PRIVATE_KEY=your-turnkey-api-private-key
# TURNKEY_API_BASE_URL=https://api.turnkey.com   # default

# Google OAuth 2.0 (for "Login with Google" on homepage)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
